# Copy this file to .env and fill in your real values.
OPENAI_API_KEY=

# Optional overrides (defaults shown)
# OPENAI_CHAT_MODEL=gpt-4o-mini
# UNDERSTANDING_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# DATA_DIR=data
# VECTORSTORE_DIR=vectorstore
# RETRIEVER_TOP_K=4
# CHROMA_PERSIST_DIR=chroma_store   # set to an absolute path (e.g. /chroma/chroma) to use a mounted volume
# CHROMA_COLLECTION_NAME=manascience_knowledge
# KNOWLEDGE_EMBEDDING_MODEL=text-embedding-3-small
# KNOWLEDGE_TOP_K=8
# KNOWLEDGE_MAX_RETURNED_CHUNKS=4
# KNOWLEDGE_MAX_CONTEXT_CHARS=6000
# RAG_SIMILARITY_THRESHOLD=0.35
# RAG_MIN_RELEVANT_CHUNKS=1
# RESPONSE_MODEL=gpt-4o-mini
# RESPONSE_TEMPERATURE=0.3
# RESPONSE_MAX_RETRIES=1
# RESPONSE_MIN_ANSWER_LENGTH=40
# RESPONSE_DOCUMENT_DUMP_SHINGLE_WORDS=12
# EMPATHY_MODEL=gpt-4o-mini
# EMPATHY_TEMPERATURE=0.5
# EMPATHY_MAX_RETRIES=1
# EMPATHY_MIN_LENGTH_RATIO=0.8
# EMPATHY_MAX_LENGTH_RATIO=2.5
# EMPATHY_FACT_RETENTION_MIN_RATIO=0.9
# SAFETY_MODEL=gpt-4o-mini
# SAFETY_TEMPERATURE=0.1
# SAFETY_MAX_RETRIES=1
# CTA_DATA_DIR=data/cta
