# KNOWLEDGE_TOP_K=8
# KNOWLEDGE_MAX_RETURNED_CHUNKS=4
# KNOWLEDGE_MAX_CONTEXT_CHARS=6000
# RAG_SIMILARITY_THRESHOLD=0.35
# RAG_MIN_RELEVANT_CHUNKS=1
# RESPONSE_MODEL=gpt-4o-mini
# RESPONSE_TEMPERATURE=0.3
# RESPONSE_MAX_RETRIES=1
# RESPONSE_MIN_ANSWER_LENGTH=40
# RESPONSE_DOCUMENT_DUMP_SHINGLE_WORDS=12
# EMPATHY_MODEL=gpt-4o-mini
# EMPATHY_TEMPERATURE=0.5
# EMPATHY_MAX_RETRIES=1
# EMPATHY_MIN_LENGTH_RATIO=0.8
# EMPATHY_MAX_LENGTH_RATIO=2.5
# EMPATHY_FACT_RETENTION_MIN_RATIO=0.9
# SAFETY_MODEL=gpt-4o-mini
# SAFETY_TEMPERATURE=0.1
# SAFETY_MAX_RETRIES=1
# CONTENT_OPTIMIZATION_MODEL=gpt-4o-mini
# CONTENT_OPTIMIZATION_TEMPERATURE=0.2
# CONTENT_OPTIMIZATION_MAX_RETRIES=1
# CONTENT_OPTIMIZATION_SKIP_MIN_WORDS=12
# CONTENT_OPTIMIZATION_SUMMARY_MIN_WORDS=50
# CONTENT_OPTIMIZATION_SUMMARY_MAX_WORDS=200
# CONTENT_OPTIMIZATION_DESCRIPTION_MIN_WORDS=50
# CONTENT_OPTIMIZATION_DESCRIPTION_MAX_WORDS=200
# CONTENT_OPTIMIZATION_KEY_POINTS_MIN=3
