# Copy this file to .env and fill in your real values.
OPENAI_API_KEY=

# Optional overrides (defaults shown)
# OPENAI_CHAT_MODEL=gpt-4o-mini
# UNDERSTANDING_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
